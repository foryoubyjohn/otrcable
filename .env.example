# Copy this file to .env and fill in the values

# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="mysql://user:password@localhost:3306/db_name?schema=public"

# Next.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# Email (for future use)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-email-password"
SMTP_FROM="OTR Cable <noreply@otrcable.com>"

# App
APP_NAME="OTR Cable Construction"
APP_URL="http://localhost:3000"
SUPPORT_EMAIL="support@otrcable.com"
CONTACT_EMAIL="info@otrcable.com"
CONTACT_PHONE="(555) 123-4567"

# API
API_URL="http://localhost:3000/api"

# Google Analytics (for future use)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
